{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "players": {
          "$playerName": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "roles": {
          ".read": "auth != null",
          ".write": "auth != null && data.parent().child('host').exists()"
        }
      }
    }
  }
}
